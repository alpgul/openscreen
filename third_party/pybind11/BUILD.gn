import("//build_overrides/build.gni")

if (build_with_chromium) {
  source_set("pybind11") {
    public_deps = [ "//third_party/pybind11" ]
  }
} else {
  config("pybind11_config") {
    include_dirs = [ "src/include" ]
  }

  source_set("pybind11") {
    public_configs = [ ":pybind11_config" ]
  }
}
